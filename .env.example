# ── Dashboard authentication (admin login) ──
# Single admin account guarding the web dashboard. Set a username and a strong
# password here. If you leave ADMIN_PASSWORD blank, a random one is generated on
# first start and printed ONCE in the server logs — log in and change it from the UI.
ADMIN_USERNAME=admin
# Set a strong password, OR leave blank to auto-generate one on first start
# (printed once in the logs) and then manage it from the UI's "Change password".
ADMIN_PASSWORD=
# Optional: supply a pre-computed bcrypt hash instead of a plaintext password.
# ADMIN_PASSWORD_HASH=
# Secret used to sign session cookies. Leave blank to auto-generate & persist one.
# Set explicitly (a long random string) to keep sessions valid across a DB reset.
SESSION_SECRET=
# Session lifetime and cookie hardening. Keep AUTH_COOKIE_SECURE=true in production
# (HTTPS). Set it to false ONLY for local http:// development.
SESSION_MAX_AGE_SECONDS=43200
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
# Brute-force protection: max failed logins per IP within the rolling window.
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=900
# Comma-separated cross-origin allowlist for the API. Leave blank for the normal
# same-origin dashboard (no CORS needed). Never use "*".
ALLOWED_ORIGINS=

# ── LiveKit Cloud ── cloud.livekit.io → Project → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini ── aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_TTS_VOICE=Aoede
USE_GEMINI_REALTIME=true
# Vobiz telephony cost per minute, in USD, added to each call's estimated spend so
# the dashboard shows all-in cost (LiveKit is treated as free). Convert your actual
# Vobiz ₹/min to USD, e.g. ₹0.50/min ÷ 83 ≈ 0.006. Set to 0 to count Gemini only.
TELEPHONY_COST_PER_MIN_USD=0.006
# Hard stop after an answered call reaches 10 minutes (billing safety guard).
MAX_CALL_DURATION_SECONDS=600

# ── Langfuse call tracing & Gemini cost observability (optional) ──
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# ── Vobiz SIP telephony ── vobiz.ai
VOBIZ_SIP_DOMAIN=xxxxxxxx.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_AUTH_ID=MA_XXXXXXXX
VOBIZ_AUTH_TOKEN=replace_with_rotated_api_token
VOBIZ_OUTBOUND_NUMBER=+919876543210
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxx
DEFAULT_TRANSFER_NUMBER=+919876543210

# ── Supabase ── supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── S3 / Supabase Storage (call recordings — optional) ──
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=https://xxxxxxxxxxxxxxxx.storage.supabase.co/storage/v1/s3
S3_REGION=ap-northeast-1
S3_BUCKET=call-recordings
RECORDING_SYNC_SECONDS=60

# ── Cal.com (calendar booking sync — optional) ──
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CALCOM_EVENT_TYPE_ID=123456
CALCOM_TIMEZONE=Asia/Kolkata

# ── Twilio SMS (confirmation texts — optional) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890

# ── Deepgram (pipeline fallback STT — optional) ──
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
